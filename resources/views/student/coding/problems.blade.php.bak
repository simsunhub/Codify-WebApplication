select">
                            @foreach($languages as $lang)
                                <option value="{{ $lang->id }}" data-slug="{{ $lang->slug }}" data-monaco="{{ $lang->monaco_language }}">{{ $lang->name }}</option>
                            @endforeach
                        </select>
                    </div>

                    <button id="runBtn" class="btn btn-primary" style="padding: 8px 20px; font-size: 13px; display: inline-flex; align-items: center; gap: 8px;">
                        <i class="fas fa-play"></i> {{ __('messages.coding.submit_btn') }}
                    </button>
                </div>

                <!-- Editor -->
                <div id="editorContainer" style="flex: 1; min-height: 0;"></div>
            </div>

            <!-- Terminal Results Drawer -->
            <div id="resultsDrawer" class="custom-scrollbar" style="background: #06060F; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 20px; flex: 2; display: flex; flex-direction: column; overflow-y: auto;">
                <h4 style="font-size: 13px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-terminal"></i> {{ __('messages.coding.console_tab') }}
                </h4>
                <div id="resultOutput" style="color: var(--text-muted); font-size: 14px; font-family: monospace; flex: 1; display: flex; align-i


































































































                }

                resultsHtml += '<div style="display:flex; flex-direction:column; gap:8px;">';
                data.test_results.forEach((res, index) => {
                    let tcStatusColor = res.status === 'passed' ? 'var(--success, #10B981)' : 'var(--danger, #EF4444)';
                    resultsHtml += `<div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.04); padding:10px; border-radius:8px; display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <span style="font-weight:600; color:#fff;">{{ __('messages.coding.test_case') }} ${index + 1}</span>
                            <span style="font-size:12px; color:var(--text-muted); margin-left:12px;">Input: ${res.input} | Expected: ${res.expected}</span>
                        </div>
                        <span style="color: ${tcStatusColor}; font-weight:700;">${res.status.toUpperCase()}</span>
                    </div>`;
                });
                resultsHtml += '</div></div>';

                outputDiv.innerHTML = resultsHtml;
            } else {
                outputDiv.innerHTML = '<span style="color:var(--danger,#EF4444)">{{ __('messages.coding.request_error') }}</span>';
            }
        })
        .catch(err => {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-play"></i> {{ __('messages.coding.submit_btn') }}';
            outputDiv.innerHTML = '<span style="color:var(--danger,#EF4444)">{{ __('messages.coding.connection_error') }}</span>';
        });
    });
</script>
@endsection
